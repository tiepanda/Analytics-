{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@src/*": [
        "./src/*"
      ],
      "@assets/*": [
        "./src/assets/*"
      ],
      "@views/*": [
        "./src/views/*"
      ],
      "@pages/*": [
        "./src/pages/*"
      ],
      "@common/*": [
        "./src/common/*"
      ],
      "@custom/*": [
        "./src/components/custom/*"
      ],
      "@dtos/*": [
        "./src/dtos/*"
      ],
      "api_ data/*": [
        "./src/api_data/*"
      ],
      "react": [
        "./node_modules/@types/react"
      ]
    },
    "target": "ES2017",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "images.d.ts",
    "src/views/auth/resetPassword",
    "src/views/widgets/data",
    ".next/types/**/*.ts",
    "src/example(app)/api/auth/[...nextauth]/route.ts",
    ".next/dev/types/**/*.ts",
    "src/app/(layout)/dashboards/analytics/page.jsx",
    "src/app/(layout)/dashboards/analytics/page.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}