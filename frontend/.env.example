# NEXT_PUBLIC_API_URL=http://103.21.232.7/ciqbe
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_IS_API_ACTIVE=false

PUBLIC_BRAND_NAME=Tecosoft.ai

# Layout Type: VERTICAL, HORIZONTAL, MODERN, BOXED, SEMIBOX
NEXT_PUBLIC_DEFAULT_LAYOUT_TYPE=VERTICAL
# Layout Mode: LIGHT, DARK, DEFAULT, BLACK_WHITE
NEXT_PUBLIC_DEFAULT_LAYOUT_MODE=LIGHT
# Layout Width: DEFAULT, FLUID
NEXT_PUBLIC_DEFAULT_LAYOUT_WIDTH=DEFAULT
# Sidebar Size: DEFAULT, MEDIUM, SMALL
NEXT_PUBLIC_DEFAULT_SIDEBAR_SIZE=DEFAULT
# Sidebar Color: LIGHT, DARK, BRAND, PURPLE, SKY
NEXT_PUBLIC_DEFAULT_SIDEBAR_COLOR=LIGHT
# Layout Direction: LTR, RTL
NEXT_PUBLIC_DEFAULT_LAYOUT_DIRECTION=LTR
# Primary Color: DEFAULT, GREEN, VIOLET, ORANGE, TEAL, FUCHSIA, LIME, AMBER
NEXT_PUBLIC_DEFAULT_DATA_COLOR=DEFAULT
# Navigation Type (for Modern layout): DEFAULT, FLOATING, BOXED, PATTERN
NEXT_PUBLIC_DEFAULT_NAVIGATION=DEFAULT
# Dark Mode Class: DEFAULT, ZINC, STONE, NEUTRAL, GRAY
NEXT_PUBLIC_DEFAULT_DARK_MODE_CLASS=DEFAULT

# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Unleash Feature Flags (Optional)
NEXT_PUBLIC_UNLEASH_URL=https://app.unleash-hosted.com/proxy
NEXT_PUBLIC_UNLEASH_CLIENT_KEY=your-client-key-here